SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database: "sqlite" needs no setup at all (default). Switch to "mysql" if you
# have a MySQL server running and want to use it instead.
DB_ENGINE=sqlite

# Only needed if DB_ENGINE=mysql
DB_NAME=task_manager_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Frontend origin allowed for CORS
CORS_ALLOWED_ORIGIN=http://localhost:3000
